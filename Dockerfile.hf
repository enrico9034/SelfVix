FROM node:22-alpine

# Installa git (necessario su Alpine)
RUN apk add --no-cache git

WORKDIR /app

# Clona il repository direttamente nella cartella /app (branch configurabile)
ARG BRANCH=main
RUN git clone --depth 1 --branch ${BRANCH} https://github.com/enrico9034/SelfVix .

# Installa le dipendenze
RUN npm install

# HF usa la porta 7860
ENV PORT=7860
EXPOSE 7860

# Compila l'addon
RUN npm run build

CMD ["npm", "start"]
